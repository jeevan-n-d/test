pipeline {
    agent { label 'DevServer' }

    parameters {
        string defaultValue: 'gowda', name: 'LASTNAME'}

    environment { NAME = "jeeva"}

    tools {
        maven 'myMaven'
    }

    stages {
        stage('build') {
            steps {
                dir('java') {   
                    sh 'mvn clean package'
                    echo "Hello ${env.NAME} ${params.LASTNAME}"
                }
            }
        }
    

    stage ('test')
    {
        parallel {
            stage('testA'){
                steps {
                    echo "This is test A"
                }
            }
            stage('testB'){
                steps {
                    echo "This is test B"
                }
            }
        }
    }


    }

 post {
        success {
            archiveArtifacts artifacts: '**/target/*.jar'
        }
    }

}