pipeline {
    agent { label 'DevServer' }

    parameters {
        string defaultValue: 'gowda', name: 'LASTNAME'}

    environment { NAME = "jeeva"}

    tools {
        maven 'myMaven'
    }

    stages {
        stage('build') {
            steps {
                dir('java') {   
                    sh 'mvn clean package'
                    echo 'Hello $NAME ${params.LASTNAME}'
                }
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: '**/target/*.jar'
        }
    }
}